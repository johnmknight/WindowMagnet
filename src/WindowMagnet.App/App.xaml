<Application x:Class="WindowMagnet.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ===== Palette ===== -->
        <SolidColorBrush x:Key="PanelBackground" Color="#0E1116" />
        <SolidColorBrush x:Key="PanelSurface"    Color="#181C24" />
        <SolidColorBrush x:Key="PanelTitleBar"   Color="#15181F" />
        <SolidColorBrush x:Key="PanelBorder"     Color="#2C313C" />
        <SolidColorBrush x:Key="PanelText"       Color="#E7E9EE" />
        <SolidColorBrush x:Key="PanelTextMuted"  Color="#C4C7CF" />
        <SolidColorBrush x:Key="PanelTextFaint"  Color="#6B7280" />
        <SolidColorBrush x:Key="AccentBrush"     Color="#4C8CFF" />
        <SolidColorBrush x:Key="LiveDotBrush"    Color="#19C37D" />
        <SolidColorBrush x:Key="HoverBorderBrush" Color="#4C8CFF" />

        <!-- Fluent / Win11 inspired (used by ProfileDialog) -->
        <SolidColorBrush x:Key="FluentAccent"        Color="#60CDFF" />
        <SolidColorBrush x:Key="FluentAccentFill"    Color="#1F60CDFF" />
        <SolidColorBrush x:Key="FluentAccentBorder"  Color="#8C60CDFF" />
        <SolidColorBrush x:Key="CardSurface"         Color="#1A1D24" />
        <SolidColorBrush x:Key="CardSurfaceSubtle"   Color="#15171D" />
        <SolidColorBrush x:Key="CardBorder"          Color="#262A33" />
        <SolidColorBrush x:Key="InputBackground"     Color="#0E1116" />

        <!-- Title-bar chrome buttons (min, close) -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#9AA1AD" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="18" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#262C36" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thumbnail tile button -->
        <Style x:Key="ThumbnailBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ContentPresenter />
                            </Border>
                            <!--
                                Separate overlay border for the keyboard-focus ring so the
                                main Bd's BorderThickness stays constant (changing thickness
                                shifts contained DWM thumbnail rects, which we don't want).
                            -->
                            <Border x:Name="FocusRing"
                                    BorderBrush="{StaticResource FluentAccent}"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    Margin="-1"
                                    IsHitTestVisible="False"
                                    Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource HoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar button (Profiles / Refresh) -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PanelTextMuted}" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource HoverBorderBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter text box -->
        <Style x:Key="FilterBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="Foreground" Value="{StaticResource PanelTextMuted}" />
            <Setter Property="CaretBrush" Value="{StaticResource PanelText}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- ===== Fluent-flavour styles for ProfileDialog ===== -->

        <!-- A card-shaped panel that groups a section's controls. -->
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,14" />
        </Style>

        <!-- Small uppercase micro-label used above each rule row. -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PanelTextFaint}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <!-- Standard text input used for offsets, widths, heights. -->
        <Style x:Key="FluentInput" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="Foreground" Value="{StaticResource PanelText}" />
            <Setter Property="CaretBrush" Value="{StaticResource PanelText}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Match-style for ComboBox (default-slot monitor picker). -->
        <Style x:Key="FluentCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="Foreground" Value="{StaticResource PanelText}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <!-- Primary action button — Save. Filled with accent. -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FluentAccent}" />
            <Setter Property="BorderBrush" Value="{StaticResource FluentAccent}" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7ED8FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button — Cancel, Add Rule, raw-JSON link. -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0E1116" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="Foreground" Value="{StaticResource PanelText}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FluentAccentBorder}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Anchor cell — one of nine in a 3x3 grid. Uses RadioButton so the group
            enforces single-selection; the template hides the radio dot and just
            tints the cell when checked.
        -->
        <Style x:Key="AnchorCell" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentAccentFill}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FluentAccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FluentAccentBorder}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Monitor card — one of however-many monitors. Same RadioButton trick,
            but the card content (the little screen visualisation) goes inside.
        -->
        <Style x:Key="MonitorCard" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Foreground" Value="{StaticResource PanelText}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentAccentFill}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FluentAccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FluentAccentBorder}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Fluent-style toggle switch built from a CheckBox so existing data-binding
            and IsChecked semantics work. Visually: 32x18 pill track + 12px thumb that
            shifts to the right when checked. Used for the per-slot ScaleDpi flag.
        -->
        <Style x:Key="FluentToggle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PanelTextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Track" Width="32" Height="18" CornerRadius="9"
                                    Background="{StaticResource CardSurfaceSubtle}"
                                    BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="Thumb" Width="12" Height="12"
                                         Fill="{StaticResource PanelTextMuted}"
                                         HorizontalAlignment="Left"
                                         Margin="3,0,0,0"
                                         VerticalAlignment="Center" />
                            </Border>
                            <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource FluentAccent}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource FluentAccent}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource PanelBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tiny round icon button used for edit/delete on rule rows. -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PanelTextMuted}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#262C36" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
