<Window x:Class="WindowMagnet.App.Dialogs.RuleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowMagnet — Rule"
        Width="500"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Display, Segoe UI Variable, Segoe UI">

    <Border Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource PanelTitleBar}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,8,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleLabel" Text="Edit rule"
                               Foreground="{StaticResource PanelText}"
                               FontSize="12" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Style="{StaticResource ChromeBtn}" Content="✕"
                            Click="Close_Click" />
                </Grid>
            </Border>

            <!-- Header strip -->
            <StackPanel Grid.Row="1" Margin="20,16,20,4">
                <TextBlock x:Name="HeaderLabel" Text="Rule"
                           Foreground="{StaticResource PanelText}"
                           FontSize="18" FontWeight="Medium" />
                <TextBlock Text="Match windows by process or title, then choose where they land."
                           Foreground="{StaticResource PanelTextFaint}"
                           FontSize="11" Margin="0,2,0,0" />
            </StackPanel>

            <!-- Body -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="540">
                <StackPanel Margin="20,8,20,16">

                    <!-- ===== Match ===== -->
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Match"
                                       Foreground="{StaticResource PanelText}"
                                       FontSize="13" FontWeight="Medium"
                                       Margin="0,0,0,8" />

                            <!-- Match-kind segmented control (two RadioButtons styled as pills) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="MatchKindProcess" Style="{StaticResource MonitorCard}"
                                             MinWidth="160" Padding="10,6" GroupName="MatchKind"
                                             IsChecked="True"
                                             Checked="MatchKind_Changed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Process name"
                                                   Foreground="{StaticResource PanelText}"
                                                   FontSize="12" FontWeight="Medium" />
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="MatchKindTitle" Style="{StaticResource MonitorCard}"
                                             MinWidth="160" Padding="10,6" GroupName="MatchKind"
                                             Checked="MatchKind_Changed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Title contains"
                                                   Foreground="{StaticResource PanelText}"
                                                   FontSize="12" FontWeight="Medium" />
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <TextBlock x:Name="MatchHint"
                                       Text="The .exe name (e.g. chrome.exe). Matched case-insensitively."
                                       Style="{StaticResource SectionLabel}"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="MatchValueBox" Style="{StaticResource FluentInput}" />
                        </StackPanel>
                    </Border>

                    <!-- ===== Slot ===== -->
                    <Border Style="{StaticResource SettingsCard}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Where it lands"
                                       Foreground="{StaticResource PanelText}"
                                       FontSize="13" FontWeight="Medium"
                                       Margin="0,0,0,8" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Monitor" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="MonitorCombo" Style="{StaticResource FluentCombo}" />

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Text="Width (px)" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                                            <TextBox x:Name="WidthBox" Style="{StaticResource FluentInput}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                            <TextBlock Text="Height (px)" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                                            <TextBox x:Name="HeightBox" Style="{StaticResource FluentInput}" />
                                        </StackPanel>
                                    </Grid>

                                    <CheckBox x:Name="ScaleDpiToggle"
                                              Style="{StaticResource FluentToggle}"
                                              Content="Scale dimensions by monitor DPI"
                                              Margin="0,10,0,0"
                                              ToolTip="When on, Width / Height above are treated as logical (100%-DPI) pixels and multiplied by the target monitor's scale." />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Anchor" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                                    <UniformGrid x:Name="AnchorGrid" Columns="3" Rows="3" Width="124" Height="124" />
                                    <TextBlock x:Name="AnchorLabel" Text="top"
                                               Foreground="{StaticResource PanelTextFaint}"
                                               FontSize="11" Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3"
                    Background="{StaticResource PanelTitleBar}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,14,20,16">
                    <Button Style="{StaticResource SecondaryBtn}" Content="Cancel"
                            Click="Cancel_Click" Margin="0,0,8,0" />
                    <Button Style="{StaticResource PrimaryBtn}" x:Name="SaveButton" Content="Save"
                            Click="Save_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
